    <div class="toast-container" id="toastContainer"></div>

    <!-- AI Chatbot Widget — Premium Redesign -->
    <div class="chatbot-widget" id="chatbotWidget">
        <button class="chatbot-trigger" id="chatbotTrigger" onclick="toggleChat()">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            <span>AI Assistant</span>
        </button>
        <div class="chatbot-window" id="chatbotWindow">
            <div class="chatbot-header">
                <div class="chatbot-header-info">
                    <div class="chatbot-header-title">CraveRush AI</div>
                    <div class="chatbot-status"><span class="chatbot-status-dot"></span> Online</div>
                </div>
                <button onclick="toggleChat()" class="chatbot-close-btn">&times;</button>
            </div>
            <div class="chatbot-messages" id="chatbotMessages">
                <div class="chat-msg bot">
                    <div class="chat-msg-content">
                        👋 Hi there! I'm your CraveRush AI assistant. How can I help you today?
                    </div>
                    <div class="chat-msg-time">${java.time.LocalTime.now().format(java.time.format.DateTimeFormatter.ofPattern("hh:mm a"))}</div>
                </div>
            </div>
            <div class="chatbot-suggestions" id="chatSuggestions">
                <button class="chat-suggestion-chip" onclick="sendQuickMessage('Track my order')">📋 Track Order</button>
                <button class="chat-suggestion-chip" onclick="sendQuickMessage('Recommend food')">🍕 Recommend Food</button>
                <button class="chat-suggestion-chip" onclick="sendQuickMessage('Show offers')">🏷️ Offers</button>
                <button class="chat-suggestion-chip" onclick="sendQuickMessage('Payment methods')">💳 Payments</button>
            </div>
            <div class="chatbot-input-area">
                <input type="text" id="chatInput" placeholder="Ask me anything..." onkeypress="handleChatKey(event)">
                <button onclick="sendChatMessage()" id="chatSendBtn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                </button>
            </div>
        </div>
    </div>

    <style>
        .chatbot-widget {
            position: fixed;
            bottom: 24px;
            left: 24px;
            z-index: 9999;
            font-family: var(--font);
        }
        .chatbot-trigger {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            border: none;
            padding: 14px 24px;
            border-radius: var(--radius-full);
            font-weight: 700;
            font-size: 0.88rem;
            cursor: pointer;
            box-shadow: 0 4px 20px rgba(252,128,25,0.4);
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 8px;
            font-family: var(--font);
        }
        .chatbot-trigger:hover {
            background: linear-gradient(135deg, var(--primary-dark), var(--accent));
            transform: translateY(-3px);
            box-shadow: 0 6px 28px rgba(252,128,25,0.5);
        }
        .chatbot-window {
            position: absolute;
            bottom: 60px;
            left: 0;
            width: 380px;
            height: 520px;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(27,31,46,0.06);
            border-radius: var(--radius-xl);
            box-shadow: var(--shadow-xl);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            opacity: 0;
            visibility: hidden;
            transform: translateY(20px) scale(0.95);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .chatbot-window.show {
            opacity: 1;
            visibility: visible;
            transform: translateY(0) scale(1);
        }
        .chatbot-header {
            background: linear-gradient(135deg, var(--secondary), var(--secondary-light));
            color: white;
            padding: 16px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .chatbot-header-title {
            font-family: var(--font-display);
            font-weight: 800;
            font-size: 0.95rem;
        }
        .chatbot-status {
            display: flex; align-items: center; gap: 6px;
            font-size: 0.7rem; opacity: 0.8;
        }
        .chatbot-status-dot {
            width: 6px; height: 6px; border-radius: 50%;
            background: #4ADE80; display: inline-block;
            animation: statusPulse 2s ease infinite;
        }
        @keyframes statusPulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }
        .chatbot-close-btn {
            background: rgba(255,255,255,0.1);
            border: none;
            color: white;
            font-size: 1.4rem;
            cursor: pointer;
            line-height: 1;
            width: 32px; height: 32px;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            transition: var(--transition);
        }
        .chatbot-close-btn:hover { background: rgba(255,255,255,0.2); }
        .chatbot-messages {
            flex: 1;
            padding: 16px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 12px;
            background: #fafbfc;
        }
        .chat-msg {
            max-width: 85%;
        }
        .chat-msg-content {
            padding: 12px 16px;
            border-radius: var(--radius-lg);
            font-size: 0.84rem;
            line-height: 1.5;
        }
        .chat-msg-time {
            font-size: 0.65rem;
            color: var(--text-muted);
            margin-top: 4px;
            padding: 0 4px;
        }
        .chat-msg.bot {
            align-self: flex-start;
        }
        .chat-msg.bot .chat-msg-content {
            background: white;
            color: var(--text-primary);
            border: 1px solid rgba(27,31,46,0.06);
            border-top-left-radius: 4px;
            box-shadow: var(--shadow-xs);
        }
        .chat-msg.user {
            align-self: flex-end;
        }
        .chat-msg.user .chat-msg-content {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            border-top-right-radius: 4px;
        }
        .chat-msg.user .chat-msg-time {
            text-align: right;
        }
        /* Typing indicator */
        .typing-indicator {
            display: flex; align-items: center; gap: 5px; padding: 14px 18px;
            background: white; border: 1px solid rgba(27,31,46,0.06);
            border-radius: var(--radius-lg); border-top-left-radius: 4px;
            width: fit-content; box-shadow: var(--shadow-xs);
        }
        .typing-dot {
            width: 7px; height: 7px; border-radius: 50%; background: var(--text-muted);
            animation: typingBounce 1.4s ease-in-out infinite;
        }
        .typing-dot:nth-child(2) { animation-delay: 0.2s; }
        .typing-dot:nth-child(3) { animation-delay: 0.4s; }
        @keyframes typingBounce {
            0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
            30% { transform: translateY(-6px); opacity: 1; }
        }
        .chatbot-suggestions {
            display: flex; gap: 6px; padding: 8px 16px; overflow-x: auto;
            border-top: 1px solid rgba(27,31,46,0.04); background: white;
        }
        .chat-suggestion-chip {
            padding: 6px 14px; border-radius: var(--radius-full);
            font-size: 0.72rem; font-weight: 600; white-space: nowrap;
            background: var(--primary-light); color: var(--primary);
            border: 1px solid rgba(252,128,25,0.15);
            cursor: pointer; transition: var(--transition); font-family: var(--font);
        }
        .chat-suggestion-chip:hover {
            background: var(--primary); color: white;
        }
        .chatbot-input-area {
            display: flex;
            border-top: 1px solid rgba(27,31,46,0.06);
            padding: 12px 16px;
            background: white;
            gap: 8px;
        }
        .chatbot-input-area input {
            flex: 1;
            border: 1.5px solid rgba(27,31,46,0.08);
            padding: 10px 16px;
            border-radius: var(--radius-full);
            font-size: 0.84rem;
            outline: none;
            font-family: var(--font);
            transition: var(--transition);
        }
        .chatbot-input-area input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(252,128,25,0.08);
        }
        .chatbot-input-area button {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            border: none;
            width: 40px; height: 40px;
            border-radius: 50%;
            cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            transition: var(--transition); flex-shrink: 0;
        }
        .chatbot-input-area button:hover {
            background: linear-gradient(135deg, var(--primary-dark), var(--accent));
            transform: scale(1.05);
        }
        @media (max-width: 480px) {
            .chatbot-window { width: 300px; height: 440px; }
        }
    </style>

    <script>
        function toggleChat() {
            const win = document.getElementById("chatbotWindow");
            win.classList.toggle("show");
            if (win.classList.contains("show")) {
                document.getElementById("chatInput").focus();
            }
        }

        function handleChatKey(event) {
            if (event.key === "Enter") {
                sendChatMessage();
            }
        }

        function sendQuickMessage(text) {
            document.getElementById("chatInput").value = text;
            sendChatMessage();
        }

        function getTimeString() {
            return new Date().toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true });
        }

        function sendChatMessage() {
            const input = document.getElementById("chatInput");
            const text = input.value.trim();
            if (!text) return;

            input.value = "";

            // Add user message
            const container = document.getElementById("chatbotMessages");
            const userMsg = document.createElement("div");
            userMsg.className = "chat-msg user";
            userMsg.innerHTML = '<div class="chat-msg-content">' + text.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</div><div class="chat-msg-time">' + getTimeString() + '</div>';
            container.appendChild(userMsg);
            container.scrollTop = container.scrollHeight;

            // Add typing indicator
            const typing = document.createElement("div");
            typing.className = "chat-msg bot";
            typing.innerHTML = '<div class="typing-indicator"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div>';
            container.appendChild(typing);
            container.scrollTop = container.scrollHeight;

            // Send API request
            fetch("${pageContext.request.contextPath}/api/chatbot", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ message: text })
            })
            .then(res => res.json())
            .then(data => {
                container.removeChild(typing);
                const botMsg = document.createElement("div");
                botMsg.className = "chat-msg bot";
                const content = data.response.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br>');
                botMsg.innerHTML = '<div class="chat-msg-content">' + content + '</div><div class="chat-msg-time">' + getTimeString() + '</div>';
                container.appendChild(botMsg);
                container.scrollTop = container.scrollHeight;
            })
            .catch(err => {
                container.removeChild(typing);
                const botMsg = document.createElement("div");
                botMsg.className = "chat-msg bot";
                botMsg.innerHTML = '<div class="chat-msg-content">Sorry, I\'m having trouble connecting right now. Please try again.</div><div class="chat-msg-time">' + getTimeString() + '</div>';
                container.appendChild(botMsg);
                container.scrollTop = container.scrollHeight;
            });
        }
    </script>

    <script src="${pageContext.request.contextPath}/js/app.js"></script>
</body>
</html>
